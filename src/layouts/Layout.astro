---
import type { MetaTags } from "../types";

interface Props {
    MetaTags: MetaTags;
}

const { MetaTags } = Astro.props;
const { title } = MetaTags;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap"
            rel="stylesheet"
        />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>

<style is:global>
    @import url("https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap");

    /* Variables */
    :root {
        --color-primary-blue: hsl(233, 26%, 24%);
        --color-primary-green: hsl(136, 64%, 51%);
        --color-primary-cyan: hsl(192, 69%, 51%);
        --color-gray-50: hsl(233, 8%, 62%);
        --color-gray-100: hsl(220, 16%, 96%);
        --color-gray-600: hsl(0, 0%, 98%);

        --breakpoint-sm: 375px;
        --breakpoint-md: 768px;
        --breakpoint-lg: 1440px;
    }

    /* CSS Reset */
    * {
        min-width: 0;
        font: inherit;
    }

    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }

    img,
    video,
    svg {
        display: block;
        max-width: 100%;
        height: auto;
    }

    body {
        font-family: "Public Sans", sans-serif;
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        min-height: 100dvh;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
        text-wrap: balance;
    }

    p {
        font-size: 18px;
        text-wrap: pretty;
    }
</style>
