---
import type { AnchorButtonType } from "../../types";

type Props = AnchorButtonType;
const { href, innerText, variant } = Astro.props;
---

<a href={href} class={`button ${variant}`}>{innerText}</a>
<style>
    .button {
        padding: 1rem 2rem;
        border-radius: 20rem;
        transition: 0.2s ease-in-out filter;

        &.primary {
            color: white;
            background: linear-gradient(
                to bottom left,
                var(--color-primary-green),
                var(--color-primary-cyan)
            );
            text-decoration: none;
        }

        &:hover {
            filter: opacity(0.5);
        }
    }
</style>
