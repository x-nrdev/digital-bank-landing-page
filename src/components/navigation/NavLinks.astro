---
import NavLink from "./NavLink.astro";
import type { NavLinks } from "../../types";
type Props = NavLinks;

const { links } = Astro.props;
---

<ul>
    {links.map((link) => <NavLink {...link} />)}
</ul>

<style>
    ul {
        display: flex;
        gap: 2rem;
        padding: 0;
        list-style: none;
    }
</style>
